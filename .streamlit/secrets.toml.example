# ─────────────────────────────────────────────────────────────────────────────
# RealEstateAI – Streamlit Secrets Template
# ─────────────────────────────────────────────────────────────────────────────
#
# LOCAL SETUP
#   1. Copy this file to .streamlit/secrets.toml
#   2. Fill in your real values
#   3. NEVER commit secrets.toml to git (it is in .gitignore)
#
# STREAMLIT CLOUD SETUP
#   1. Go to your app → "Manage app" → "Secrets"
#   2. Paste the contents of this file (with real values filled in)
#   3. Click Save → app restarts automatically
#
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI API key (required for AI Analyst Chat + knowledge base)
OPENAI_API_KEY = "sk-your-openai-api-key-here"


# ── Access Codes ──────────────────────────────────────────────────────────────
# Each entry maps an access code → referrer/realtor name.
# Codes are case-insensitive.
#
# To ADD a new realtor:   add a line below, save → live immediately
# To REVOKE a code:       delete the line, save → invalid immediately
# No code deploy needed — secrets changes take effect instantly.

[access_codes]
"DUFF-DEMO" = "Demo / General Access"
"DUFF-R01"  = "Jane Smith – Keller Williams Dayton"
"DUFF-R02"  = "Bob Jones – RE/MAX Preferred"
"DUFF-R03"  = "Susan Lee – Coldwell Banker"


# ── SMTP (Lead Capture Email) ─────────────────────────────────────────────────
# When a user logs in with a valid code, an email is sent to Frederick with
# their contact info and which code/referrer they used.
#
# Uses Gmail SMTP with an App Password (NOT your regular Gmail password).
# To create an App Password:
#   1. Sign in to Google → Security → 2-Step Verification (must be ON)
#   2. Search for "App passwords" → create one for "Mail"
#   3. Paste the 16-character password below (spaces optional)

[smtp]
sender_email    = "your-gmail-address@gmail.com"
sender_password = "xxxx xxxx xxxx xxxx"     # 16-char Gmail App Password
recipient_email = "FDuff@QueenCitymortgage.net"
